# Copy this file to .env and fill in your real values.
# Vite only exposes variables prefixed with VITE_ to the browser.

# Django REST API base URL (the `catalog` app under /api/)
VITE_API_BASE_URL=http://127.0.0.1:8000/api

# WhatsApp business number, digits only, country code first (no + or spaces)
VITE_WHATSAPP_NUMBER=919999999999

# Your Cloudinary cloud name (from Cloudinary dashboard) — used to build
# delivery URLs when the backend stores bare public_ids instead of full URLs
VITE_CLOUDINARY_CLOUD_NAME=your_cloud_name

# Optional
VITE_SITE_NAME=HR Frames
VITE_CONTACT_EMAIL=orders@hrframes.in
VITE_INSTAGRAM_URL=
VITE_FACEBOOK_URL=
